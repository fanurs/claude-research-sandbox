services:
  sandbox:
    build: .
    container_name: __PROJECT_NAME__-sandbox
    init: true
    restart: unless-stopped
    shm_size: 16g
    ipc: host
    volumes:
      - .:/workspace
    cap_drop:
      - ALL
    cap_add:
      - CHOWN
      - DAC_OVERRIDE
      - SETGID
      - SETUID
    # Note: no-new-privileges removed — it breaks NVML/GPU access inside container
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: all
              capabilities: [gpu]
